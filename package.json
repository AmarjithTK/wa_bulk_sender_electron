{
  "name": "whatsapp-sender-gui",
  "version": "1.1.3",
  "description": "Desktop WhatsApp bulk sender with multi-session campaigns",
  "main": "main.js",
  "author": "AmarjithTK",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@material/web": "^1.3.0",
    "call-bind": "^1.0.2",
    "call-bind-apply-helpers": "latest",
    "dunder-proto": "latest",
    "get-intrinsic": "^1.2.0",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.34.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sinspire.whatsbulk",
    "productName": "WhatsApp Message Sender",
    "icon": "assets/iconkitchen/web/icon-512.png",
    "asar": true,
    "files": [
      "**/*",
      "!browser/**/*",
      "!build.sh",
      "!.gitignore"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Utility",
      "maintainer": "AmarjithTK amarjithraveendran@gmail.com",
      "icon": "assets/iconkitchen/web/icon-512.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
