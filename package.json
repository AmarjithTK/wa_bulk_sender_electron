{
  "name": "whatsapp-sender-gui",
  "version": "1.1.8",
  "description": "Desktop WhatsApp bulk sender with multi-session campaigns",
  "main": "main.js",
  "author": "AmarjithTK",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "dependencies": {
    "@material/web": "^1.3.0",
    "call-bind": "^1.0.2",
    "call-bind-apply-helpers": "latest",
    "dunder-proto": "latest",
    "get-intrinsic": "^1.2.0",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "whatsapp-web.js": "^1.34.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.sinspire.whatsbulk",
    "productName": "WhatsApp Message Sender",
    "icon": "assets/iconkitchen/web/icon-512.png",
    "copyright": "Copyright (c) 2026 AmarjithTK",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "files": [
      "**/*",
      "!browser/**/*",
      "!build.sh",
      "!.gitignore"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "WhatsApp Message Sender ${version}",
      "background": "assets/showcase1.png",
      "icon": "assets/iconkitchen/web/icon-512.png",
      "window": {
        "width": 640,
        "height": 420
      },
      "contents": [
        {
          "x": 180,
          "y": 210,
          "type": "file"
        },
        {
          "x": 460,
          "y": 210,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "assets/iconkitchen/web/icon-512.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "WhatsApp Message Sender",
      "uninstallDisplayName": "WhatsApp Message Sender",
      "displayLanguageSelector": true,
      "license": "LICENSE_INSTALLER.txt"
    },
    "linux": {
      "category": "Utility",
      "maintainer": "AmarjithTK amarjithraveendran@gmail.com",
      "icon": "assets/iconkitchen/web/icon-512.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
